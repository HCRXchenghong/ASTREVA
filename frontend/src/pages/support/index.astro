---
import ContactForm from '../../components/ContactForm';
import BaseLayout from '../../layouts/BaseLayout.astro';
import InnerPageHero from '../../components/InnerPageHero.astro';
import { contactPageJsonLd } from '../../lib/seo';
import { getContent } from '../../lib/content';

const content = await getContent();
const support = content.support;
const iconMap = { shield: '盾', wrench: '工', help: '?' };
const phoneIcon = support.contact.phoneIcon || '☎';
const emailIcon = support.contact.emailIcon || '✉';
---

<BaseLayout content={content} seo={support.seo} path="/support/" jsonLd={[contactPageJsonLd(content.site)]}>
  <div class="w-full pt-24">
    <InnerPageHero
      id="support-hero"
      title={support.hero.title}
      description={support.hero.description}
      backgroundImage={support.hero.backgroundImage}
      backgroundVideo={support.hero.backgroundVideo}
    />
    <div class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div id="support-services" class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-24 scroll-mt-24">
          {support.services.map((service) => {
            const icon = iconMap[service.icon as keyof typeof iconMap] || service.icon || '?';
            return (
              <div class="bg-blue-50 p-10 rounded-3xl text-center hover:-translate-y-2 transition-transform shadow-sm">
                <div class="text-[#0a66c2] mx-auto mb-6 text-5xl font-black">{icon}</div>
                <h3 class="text-2xl font-bold mb-4">{service.title}</h3>
                <p class="text-gray-600 mb-6 text-sm">{service.description}</p>
                <a href={service.href} class="text-[#0a66c2] font-bold hover:underline">{service.cta} &rarr;</a>
              </div>
            );
          })}
        </div>
        <div id="support-contact" class="max-w-4xl mx-auto bg-white rounded-3xl shadow-[0_8px_30px_rgb(0,0,0,0.08)] overflow-hidden border border-gray-100 flex flex-col md:flex-row scroll-mt-24">
          <div class="bg-[#0a4d8c] text-white p-12 md:w-2/5 flex flex-col justify-between">
            <div>
              <h3 class="text-3xl font-bold mb-6">{support.contact.title}</h3>
              <p class="text-blue-200 mb-8 leading-relaxed">{support.contact.description}</p>
              <div class="space-y-6">
                <div class="flex items-center gap-4">
                  <span class="text-blue-300 text-2xl" aria-hidden="true">{phoneIcon}</span>
                  <div><p class="text-sm text-blue-200">{support.contact.phoneLabel}</p><p class="font-bold text-lg">{content.site.phone}</p></div>
                </div>
                <div class="flex items-center gap-4">
                  <span class="text-blue-300 text-2xl" aria-hidden="true">{emailIcon}</span>
                  <div><p class="text-sm text-blue-200">{support.contact.emailLabel}</p><p class="font-bold text-lg">{content.site.email}</p></div>
                </div>
              </div>
            </div>
          </div>
          <div class="p-12 md:w-3/5">
            <ContactForm client:load form={support.contact.form} />
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
