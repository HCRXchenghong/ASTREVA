---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getContent, productsForCategory } from '../../lib/content';

const content = await getContent();
const productCenter = content.productCenter;
const seo = productCenter.seo;
const categoryCtaIcon = productCenter.categoryPage.categoryCtaIcon || '→';
const categories = [...content.categories].sort((a, b) => a.sortOrder - b.sortOrder);
const activeCategory = categories.find((item) => item.slug === 'commercial-premium-residential') || categories[0];
const visibleProducts = activeCategory ? productsForCategory(content, activeCategory.slug).slice(0, 4) : [];

const productTags = ['隐形收边', '快速安装', '景观节点'];
---

<BaseLayout content={content} seo={seo} path="/products/">
  <div class="w-full pt-24 bg-[#f7f8f6] min-h-screen">
    <section class="border-b border-[#d9dee5] bg-[#f8f9f8]">
      <div class="max-w-7xl mx-auto px-6 py-10 md:py-12">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
          <div class="max-w-2xl">
            <p class="text-xs font-bold uppercase tracking-[0.24em] text-[#b88923]">Product Center</p>
            <h1 class="mt-3 text-4xl md:text-5xl font-black text-[#172033]">{productCenter.hero.title}</h1>
            <p class="mt-4 text-base md:text-lg leading-8 text-[#5d6676]">{productCenter.hero.description}</p>
          </div>
          <div class="h-px w-full bg-[#d9dee5] lg:h-28 lg:w-px"></div>
          <p class="max-w-sm text-sm leading-7 text-[#6b7280]">
            {productCenter.intro.description}
          </p>
        </div>
      </div>
    </section>

    <section id="product-categories" class="scroll-mt-24 border-b border-[#d9dee5] bg-[#f3f5f4]">
      <div class="max-w-7xl mx-auto px-6 py-7">
        <div class="flex flex-col gap-4 xl:flex-row xl:items-center">
          <span class="text-sm md:text-base font-extrabold text-[#596272] whitespace-nowrap">{content.site.navigation.categoryPrompt.replace(' :', '').replace(':', '')}</span>
          <div class="flex flex-wrap gap-3">
            {categories.map((item, index) => {
              const active = item.slug === activeCategory?.slug;
              return (
                <a
                  href={`/products/${item.slug}/`}
                  class={`group inline-flex items-center gap-3 rounded-xl border px-5 py-3 text-sm md:text-base font-extrabold transition-all ${
                    active
                      ? 'border-[#0a66c2] bg-[#0a66c2] text-white shadow-[0_12px_24px_rgba(10,102,194,0.22)]'
                      : 'border-[#d8dee7] bg-white text-[#303a4b] hover:border-[#9fb7d1] hover:text-[#0a5ca8]'
                  }`}
                >
                  <span class={`text-[11px] font-black ${active ? 'text-white/70' : 'text-[#a3acba]'}`}>{String(index + 1).padStart(2, '0')}</span>
                  {item.name}
                </a>
              );
            })}
          </div>
        </div>
      </div>
    </section>

    {activeCategory && (
      <section class="py-16 md:py-20">
        <div class="max-w-7xl mx-auto px-6">
          <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
            <div>
              <p class="text-sm font-bold text-[#b88923]">当前业务分类</p>
              <h2 class="mt-2 text-3xl md:text-4xl font-black text-[#182235]">{activeCategory.name}</h2>
              <p class="mt-3 max-w-2xl text-base leading-8 text-[#667085]">{activeCategory.description}</p>
            </div>
            <a href={`/products/${activeCategory.slug}/`} class="inline-flex items-center gap-2 text-sm font-extrabold text-[#0a66c2] hover:text-[#084b8c]">
              查看完整分类 <span aria-hidden="true">{categoryCtaIcon}</span>
            </a>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            {visibleProducts.map((item, index) => (
              <a href={`/products/${item.categorySlug}/${item.slug}/`} class="group overflow-hidden rounded-xl border border-[#dfe4ea] bg-white shadow-[0_14px_40px_rgba(18,32,54,0.06)] transition-all duration-300 hover:-translate-y-1 hover:border-[#9fb7d1] hover:shadow-[0_20px_48px_rgba(18,32,54,0.12)]">
                <div class="grid min-h-[260px] grid-cols-1 md:grid-cols-[230px_1fr]">
                  <div
                    class="relative min-h-[210px] overflow-hidden bg-[linear-gradient(135deg,#d7dde3,#f6f7f6)]"
                    style={`background-image: linear-gradient(135deg, rgba(10,77,140,0.10), rgba(184,137,35,0.10)), url('${item.coverImage}'); background-size: cover; background-position: center;`}
                  >
                    <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(255,255,255,0)_45%,rgba(10,31,57,0.35))]"></div>
                    <span class="absolute left-4 top-4 rounded-full bg-white/90 px-3 py-1 text-[11px] font-black text-[#0a4d8c] shadow-sm">ASTREVA {String(index + 1).padStart(2, '0')}</span>
                  </div>
                  <div class="flex flex-col justify-between p-7">
                    <div>
                      <div class="mb-5 h-[3px] w-12 bg-[#b88923]"></div>
                      <h3 class="text-2xl font-black leading-tight text-[#172033] group-hover:text-[#0a5ca8] transition-colors">{item.name}</h3>
                      <p class="mt-4 text-sm leading-7 text-[#667085]">{item.summary}</p>
                      <div class="mt-5 flex flex-wrap gap-2">
                        {productTags.map((tag) => (
                          <span class="rounded-full border border-[#dfe4ea] bg-[#f7f8f6] px-3 py-1 text-xs font-bold text-[#536173]">{tag}</span>
                        ))}
                      </div>
                    </div>
                    <span class="mt-8 inline-flex items-center gap-2 text-sm font-extrabold text-[#0a66c2]">
                      {productCenter.intro.categoryCtaLabel} <span class="transition-transform group-hover:translate-x-1" aria-hidden="true">{categoryCtaIcon}</span>
                    </span>
                  </div>
                </div>
              </a>
            ))}
          </div>

          <div class="mt-12 grid grid-cols-1 gap-4 md:grid-cols-4">
            {categories.map((item) => (
              <a href={`/products/${item.slug}/`} class="group border-t border-[#d8dee7] pt-5 text-left transition-colors hover:border-[#0a66c2]">
                <p class="text-sm font-black text-[#172033] group-hover:text-[#0a5ca8]">{item.name}</p>
                <p class="mt-2 text-xs leading-6 text-[#7b8492] line-clamp-2">{item.description}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </div>
</BaseLayout>
